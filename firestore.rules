rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /lessons/{lessonId} {
      allow read, write: if true;
    }
    match /scores/{scoreId} {
      allow read, write: if true;
    }
    match /teachers/{teacherCode} {
      allow read, write: if true;
    }
    match /classes/{classCode} {
      allow read, write: if true;
    }
    match /configs/{configId} {
      allow read, write: if true;
    }
  }
}
